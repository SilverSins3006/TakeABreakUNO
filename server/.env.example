# ==========================================
# DATABASE CONFIGURATION (Neon PostgreSQL)
# ==========================================
# Get DATABASE_URL from Discord #Links channel.
# Ensure URL ends with "?sslmode=require".
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=3000

# ==========================================
# FUTURE VARIABLES (Uncomment & Add values when implementing features)
# ==========================================

# [Milestone 2/3 - Notifications] If enabling browser push notifications:
# Required VAPID public key for Web Push protocol.
# BROWSER_NOTIFICATION_KEY=""

# [Milestone 3 - Auth] If adding user login/signup:
# Required to sign JWT tokens. Generate a strong random string.
# NEVER commit the actual secret to GitHub!
# JWT_SECRET="" 

# ==========================================
# OPTIONAL: API KEYS (if using 3rd party services later)
# ==========================================
API_KEY="" 
