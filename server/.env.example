# ==========================================
# DATABASE CONFIGURATION (Neon PostgreSQL)
# ==========================================
# Get DATABASE_URL from Discord #Links channel.
# Ensure URL ends with "?sslmode=require".
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=3000

# ==========================================
# AUTH0 CONFIGURATION (Milestone 2 - Core Auth)
# ==========================================
# The unique identifier set up in your Auth0 API settings (e.g., https://api.myapp.com)
AUTH0_AUDIENCE="your-api-identifier"

# The domain of your Auth0 tenant (e.g., https://your-tenant.us.auth0.com/)
AUTH0_ISSUER_BASE_URL="https://your-auth0-domain.com/"

# ==========================================
# FUTURE VARIABLES (Uncomment & Add values when implementing features)
# ==========================================
# BROWSER_NOTIFICATION_KEY=""

# ==========================================
# OPTIONAL: API KEYS (if using 3rd party services later)
# ==========================================
API_KEY=""